# Normalize line endings: LF in the repository, native in the working tree.
* text=auto

# Source
*.ino   text diff=cpp
*.h     text diff=cpp
*.py    text diff=python
*.html  text diff=html
*.md    text
*.txt   text

# Binary assets — never munge these
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.stl   binary
*.3mf   binary
*.f3d   binary
*.step  binary
*.zip   binary
