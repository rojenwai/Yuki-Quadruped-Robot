# Copy this file to .env and fill in your values (.env is gitignored).

# --- Robot connection ---
# IP or mDNS host of the robot. Use "yuki.local" if the firmware advertises mDNS,
# a static IP (e.g. 192.168.1.100), or "mock" to run without hardware.
YUKI_ROBOT_IP=yuki.local

# --- AI backend ---
# false = Google Gemini (cloud), true = local OpenAI-compatible LLM (Ollama/LM Studio)
YUKI_LOCAL=false

# Required when YUKI_LOCAL=false. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Used when YUKI_LOCAL=true (OpenAI-compatible endpoint + model name)
LOCAL_LLM_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3

# --- Voice / TTS ---
VOICE_ENABLED=true
# pyttsx3 (offline) or gemini (cloud, needs GEMINI_API_KEY + pygame)
TTS_ENGINE=pyttsx3
WAKE_WORD=hey yuki
WAKE_WORD_MODE=false

# --- Behavior ---
# Seconds to keep walking/turning before auto-stopping. 0 = run until "stop".
MOVE_DURATION=0
# Set to true to print raw AI interpretations for debugging.
DEBUG=false
